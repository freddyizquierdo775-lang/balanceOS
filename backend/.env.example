"""
Balance OS — Variables de Entorno
==================================
Copia este archivo como .env y configura los valores.

Ejemplo:
  cp .env.example .env
  # Editar .env con tus valores
"""

# ─── JWT ─────────────────────────────────────────
# Clave secreta para firmar tokens JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

# ─── PAC (Proveedor Autorizado de Certificación) ──
# Opciones: mock (desarrollo), facturaxion, swsaps, finkok
PAC_PROVIDER=mock

# API Key del PAC
PAC_API_KEY=

# API Secret del PAC
PAC_API_SECRET=

# Cuenta / RFC del PAC
PAC_ACCOUNT=

# Endpoint personalizado (opcional, default según provider)
# PAC_ENDPOINT=https://api.facturaxion.com/v1

# ─── Servidor ────────────────────────────────────
PORT=8000
HOST=0.0.0.0
